# 服务器配置
APP_SERVER_PORT=8080
APP_SERVER_MODE=debug
APP_SERVER_READ_TIMEOUT=30
APP_SERVER_WRITE_TIMEOUT=30
APP_SERVER_IDLE_TIMEOUT=60

# 数据库配置
APP_DATABASE_DRIVER=mysql
APP_DATABASE_HOST=localhost
APP_DATABASE_PORT=3306
APP_DATABASE_USERNAME=root
APP_DATABASE_PASSWORD=password
APP_DATABASE_DATABASE=enterprise_db
APP_DATABASE_MAX_OPEN_CONNS=100
APP_DATABASE_MAX_IDLE_CONNS=10
APP_DATABASE_CONN_MAX_LIFETIME=3600

# Redis配置
APP_REDIS_HOST=localhost
APP_REDIS_PORT=6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0
APP_REDIS_POOL_SIZE=10
APP_REDIS_MIN_IDLE_CONNS=5

# 日志配置
APP_LOG_LEVEL=info
APP_LOG_FORMAT=json
APP_LOG_OUTPUT=stdout
APP_LOG_MAX_SIZE=100
APP_LOG_MAX_BACKUPS=3
APP_LOG_MAX_AGE=7
APP_LOG_COMPRESS=true

# JWT配置
APP_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
APP_JWT_EXPIRE_TIME=7200
APP_JWT_ISSUER=go-enterprise-template

# 监控配置
APP_METRICS_ENABLED=true
APP_METRICS_PATH=/metrics
APP_METRICS_PORT=9090

# 链路追踪配置
APP_TRACING_ENABLED=true
APP_TRACING_SERVICE_NAME=go-enterprise-service
APP_TRACING_ENDPOINT=http://localhost:14268/api/traces
APP_TRACING_SAMPLE_RATE=0.1