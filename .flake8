[flake8]
max-line-length = 88
extend-ignore = E203, E266, E501, W503
max-complexity = 18
select = B,C,E,F,W,T4,B9
exclude = 
    .git,
    __pycache__,
    .venv,
    .eggs,
    *.egg,
    build,
    dist,
    docs,
    migrations,
    .mypy_cache,
    .pytest_cache

per-file-ignores =
    __init__.py:F401
    tests/*:S101,S106